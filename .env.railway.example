# ══════════════════════════════════════════════════════════════
# SchoolOS v5.4 — Railway Environment Variables Template
# ══════════════════════════════════════════════════════════════
# انسخ هذا إلى Railway Dashboard → Variables
# Railway يوفر DATABASE_URL + REDIS_URL تلقائياً

# ── Django Core ────────────────────────────────────────────────
DJANGO_SETTINGS_MODULE=shschool.settings.production
SECRET_KEY=<GENERATE_WITH: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())">
DEBUG=False
ALLOWED_HOSTS=.up.railway.app,.railway.app

# ── Security ───────────────────────────────────────────────────
FERNET_KEY=<GENERATE_WITH: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())">
SECURE_SSL_REDIRECT=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
SECURE_HSTS_SECONDS=31536000
SECURE_PROXY_SSL_HEADER=HTTP_X_FORWARDED_PROTO,https

# ── Database (Railway auto-injects DATABASE_URL) ───────────────
# DATABASE_URL is automatically provided by Railway PostgreSQL plugin
# Format: postgresql://user:password@host:port/dbname

# ── Redis (Railway auto-injects REDIS_URL) ─────────────────────
# REDIS_URL is automatically provided by Railway Redis plugin
CELERY_BROKER_URL=${REDIS_URL}
CELERY_RESULT_BACKEND=${REDIS_URL}

# ── Static Files (Railway uses Whitenoise) ─────────────────────
STATIC_URL=/static/
STATIC_ROOT=/app/staticfiles
MEDIA_URL=/media/
MEDIA_ROOT=/app/media

# ── Metrics & Monitoring ───────────────────────────────────────
METRICS_ALLOWED_IPS=127.0.0.1,::1

# ── Sentry (Optional) ──────────────────────────────────────────
# SENTRY_DSN=https://your-key@sentry.io/your-project
APP_VERSION=v5.4

# ── First Deploy — Superuser (Optional) ────────────────────────
# DJANGO_SUPERUSER_USERNAME=admin
# DJANGO_SUPERUSER_EMAIL=admin@schoolos.qa
# DJANGO_SUPERUSER_PASSWORD=<strong-password>

# ── Qatar-specific (PDPPL) ─────────────────────────────────────
TIME_ZONE=Asia/Qatar
LANGUAGE_CODE=ar
PDPPL_DATA_RETENTION_DAYS=730

# ── Email (Optional — for notifications) ───────────────────────
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.sendgrid.net
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=apikey
# EMAIL_HOST_PASSWORD=<sendgrid-api-key>
# DEFAULT_FROM_EMAIL=noreply@schoolos.qa

# ── Twilio (Optional — for WhatsApp/SMS) ───────────────────────
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_WHATSAPP_NUMBER=

# ── VAPID Push Notifications (Optional) ────────────────────────
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_CLAIM_EMAIL=mailto:admin@schoolos.qa
