# ══════════════════════════════════════════════
#  SchoolOS — إعدادات البيئة
#  انسخ هذا الملف إلى .env وعدّل القيم
# ══════════════════════════════════════════════

# ── Core Django ───────────────────────────────
SECRET_KEY=your-secret-key-here-min-50-chars-replace-this
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# ── Database ──────────────────────────────────
DB_NAME=shschool_db
DB_USER=shschool_user
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432
# للـ Docker: DB_HOST=db

# ── Media & Static ────────────────────────────
MEDIA_ROOT=media
STATIC_ROOT=staticfiles

# ── Email (console للتطوير، smtp للإنتاج) ────
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your@email.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=noreply@schoolos.qa

# ── Redis (اختياري — للـ Cache والـ Sessions) ──
# REDIS_URL=redis://localhost:6379/0
# للـ Docker: REDIS_URL=redis://redis:6379/0

# ── تشفير البيانات الصحية (اختياري) ──────────
# احصل على المفتاح عبر:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# FERNET_KEY=your-fernet-key-here
