# ══════════════════════════════════════════════
#  SchoolOS — إعدادات البيئة
#  انسخ هذا الملف إلى .env وعدّل القيم
# ══════════════════════════════════════════════

# ── Core Django ───────────────────────────────
SECRET_KEY=your-secret-key-here-min-50-chars-replace-this
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# ── Database ──────────────────────────────────
DB_NAME=shschool_db
DB_USER=shschool_user
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432
# للـ Docker: DB_HOST=db

# ── Media & Static ────────────────────────────
MEDIA_ROOT=media
STATIC_ROOT=staticfiles

# ── Email (console للتطوير، smtp للإنتاج) ────
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your@email.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=noreply@schoolos.qa

# ── Redis ─────────────────────────────────────
# كلمة مرور Redis — مطلوبة في الإنتاج (غيّر هذه القيمة حتمًا)
REDIS_PASSWORD=change_me_to_a_strong_redis_password
# REDIS_URL للتطوير المحلي (بدون password)
# REDIS_URL=redis://localhost:6379/0
# REDIS_URL للـ Docker Compose (مع password)
# REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379/0

# ── AWS S3 Backup (اختياري) ───────────────────
# عند الضبط، تُرفع النسخ الاحتياطية تلقائيًا لـ S3 بعد الحفظ المحلي
# AWS_BACKUP_BUCKET=
# AWS_S3_REGION_NAME=me-south-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# ── تشفير البيانات الصحية (اختياري) ──────────
# احصل على المفتاح عبر:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# FERNET_KEY=your-fernet-key-here

# ✅ v5: VAPID Push Notifications
# شغّل: python manage.py generate_vapid_keys لتوليد مفاتيح جديدة
VAPID_PRIVATE_KEY=your_vapid_private_key_here
VAPID_PUBLIC_KEY=your_vapid_public_key_here
VAPID_PUBLIC_KEY_B64=your_vapid_public_key_base64url_here
VAPID_CLAIMS_EMAIL=s.mesyef0904@education.qa

# ✅ DPO — مسؤول حماية البيانات (PDPPL م.17)
DPO_NAME=سفيان احمد محمد مسيف
DPO_EMAIL=s.mesyef0904@education.qa
DPO_PHONE=55296286
