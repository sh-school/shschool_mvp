            return false;
        }
    var emailPat = /\w+([-+.']\w+)*@\w+([-.]\w+)*\.\w+([-.]\w+)*/;
    var emailid = document.getElementById("txtEmailFooter").value;
    var matchArray = emailid.match(emailPat);
