                $("[id$=txtEmailFooter]").attr("aria-describedby", $('[id$=litMsgStatus]')[0].id);
                $("[id$=txtEmailFooter]").attr("aria-invalid", "true");
                document.getElementById("txtEmailFooter").focus();

                return false;
            }
        }
        else if (document.getElementById("txtEmailFooter").value == "" || document.getElementById("txtEmailFooter").value == "Please enter your email") {
            document.getElementById("litMsgStatus").style.display = "block";
            document.getElementById("litMsgStatus").innerHTML = "Please enter your email";
