    function validate() {

        if (window.location.href.indexOf("/arabic") > -1) {
            if (document.getElementById("txtEmailFooter").value == "" || document.getElementById("txtEmailFooter").value == "رجاءً أدخل بريدك الإلكتروني") {
                document.getElementById("litMsgStatus").style.display = "block";
