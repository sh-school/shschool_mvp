        document.getElementById("litMsgStatus").style.display = "block";
        if (window.location.href.indexOf("/arabic") > -1) {
            document.getElementById("litMsgStatus").innerHTML = "بريد إلكترونى غير صحيح";
        }
        else {
            document.getElementById("litMsgStatus").innerHTML = "Invalid email address";
        }
        $("[id$=txtEmailFooter]").attr("aria-describedby", $('[id$=litMsgStatus]')[0].id);
        $("[id$=txtEmailFooter]").attr("aria-invalid", "true");
        document.getElementById("txtEmailFooter").focus();
         return false;
     }
