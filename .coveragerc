[run]
source = .
omit =
    */migrations/*
    */management/commands/*
    manage.py
    setup_fonts.py
    shschool/settings/development.py
    shschool/settings/production.py
    shschool/wsgi.py
    shschool/asgi.py
    */tests/*
    .venv/*
    .claude/*

[report]
exclude_lines =
    pragma: no cover
    def __repr__
    if __name__ == .__main__
    raise NotImplementedError
show_missing = true
