{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Django Dev Server",
      "runtimeExecutable": "D:/shschool_mvp/.venv/Scripts/python.exe",
      "runtimeArgs": ["D:/shschool_mvp/manage.py", "runserver", "8000"],
      "port": 8000,
      "env": {
        "DJANGO_SETTINGS_MODULE": "shschool.settings.development"
      }
    },
    {
      "name": "Tailwind CSS Watch",
      "runtimeExecutable": "npx",
      "runtimeArgs": [
        "tailwindcss",
        "-c", "tailwind.config.js",
        "-i", "static/css/tailwind_input.css",
        "-o", "static/css/tailwind.min.css",
        "--watch"
      ],
      "port": 3000
    },
    {
      "name": "Celery Worker",
      "runtimeExecutable": "python",
      "runtimeArgs": ["-m", "celery", "-A", "shschool", "worker", "-l", "info"],
      "port": 6379
    },
    {
      "name": "Icon Preview",
      "runtimeExecutable": "D:/shschool_mvp/.venv/Scripts/python.exe",
      "runtimeArgs": ["-m", "http.server", "8099", "--directory", "D:/shschool_mvp/staticfiles"],
      "port": 8099
    },
    {
      "name": "Celery Beat",
      "runtimeExecutable": "python",
      "runtimeArgs": ["-m", "celery", "-A", "shschool", "beat", "-l", "info"],
      "port": 6380
    }
  ]
}
